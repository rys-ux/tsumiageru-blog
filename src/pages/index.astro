---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

function formatDate(date: Date) {
  return date.toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout title="積み上げる20代" description="20代の学びと積み上げを記録するブログ">
  <div class="page-container">
    <section class="hero">
      <span class="hero-emoji">📚</span>
      <h1 class="hero-title">積み上げる20代</h1>
      <p class="hero-description">
        日々の学び・挑戦・気づきを積み上げていく記録です。
      </p>
    </section>

    <section class="posts-section">
      <h2 class="section-title">最新の記事</h2>
      {posts.length === 0 ? (
        <div class="empty-state">
          <p>まだ記事がありません。</p>
        </div>
      ) : (
        <ul class="post-list">
          {posts.map((post) => (
            <li>
              <a href={`/blog/${post.id}`} class="post-card">
                <div class="card-emoji" aria-hidden="true">{post.data.emoji}</div>
                <div class="card-content">
                  <h3 class="card-title">{post.data.title}</h3>
                  <p class="card-description">{post.data.description}</p>
                  <div class="card-meta">
                    <time class="card-date" datetime={post.data.pubDate.toISOString()}>
                      {formatDate(post.data.pubDate)}
                    </time>
                    {post.data.tags.length > 0 && (
                      <div class="card-tags">
                        {post.data.tags.slice(0, 3).map((tag) => (
                          <span class="tag">#{tag}</span>
                        ))}
                      </div>
                    )}
                  </div>
                </div>
              </a>
            </li>
          ))}
        </ul>
      )}
    </section>
  </div>
</BaseLayout>

<style>
  .page-container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .hero {
    text-align: center;
    padding: 3rem 1rem 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
  }

  .hero-emoji {
    font-size: 2.5rem;
    display: block;
    margin-bottom: 0.5rem;
  }

  .hero-title {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
  }

  .hero-description {
    font-size: 1rem;
    color: var(--color-text-secondary);
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .section-title {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .post-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .post-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    color: var(--color-text-primary);
    transition: box-shadow var(--transition), border-color var(--transition), transform var(--transition);
  }

  .post-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--color-accent);
    transform: translateY(-2px);
    color: var(--color-text-primary);
  }

  .card-emoji {
    font-size: 2.25rem;
    line-height: 1;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .card-content {
    flex: 1;
    min-width: 0;
  }

  .card-title {
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1.45;
    margin-bottom: 0.4rem;
    color: var(--color-text-primary);
    transition: color var(--transition);
  }

  .post-card:hover .card-title {
    color: var(--color-accent);
  }

  .card-description {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 0.75rem;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .card-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem;
  }

  .card-date {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tag {
    font-size: 0.75rem;
    color: var(--color-tag-text);
    background-color: var(--color-tag-bg);
    padding: 0.15rem 0.55rem;
    border-radius: 20px;
    font-weight: 500;
  }

  .empty-state {
    text-align: center;
    padding: 4rem 1rem;
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  @media (max-width: 600px) {
    .hero {
      padding: 2rem 0.5rem 2rem;
    }

    .hero-title {
      font-size: 1.5rem;
    }

    .post-card {
      padding: 1rem;
      gap: 0.75rem;
    }

    .card-emoji {
      font-size: 1.75rem;
    }

    .card-title {
      font-size: 1rem;
    }
  }
</style>
